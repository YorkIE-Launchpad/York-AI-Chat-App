# Production env for packaged builds (`npm run build`).
# Copy to `.env.prod` and fill in production Hub / Cognito values.
# Dev continues to use `.env`.

# Hub / Cognito authentication
HUB_API_URL=https://api.hub.yorkdevs.link
VITE_HUB_API_URL=https://api.hub.yorkdevs.link
LAUNCHPAD_MCP_URL=https://launchpad.yorkdevs.link/mcp
HUB_MCP_URL=https://mcp.hub.yorkdevs.link/mcp
GTM_PULSE_MCP_URL=https://gtm-pulse.yorkdevs.link/mcp
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_APP_CLIENT_ID=
AUTH_ALLOWED_DOMAIN=@york.ie

# Desktop OAuth: Hub must allow http://127.0.0.1:<port>/auth/callback
# VITE_FRONTEND_URL / VITE_HUB_OAUTH_REDIRECT_URL are mainly for Vite-dev;
# packaged builds use the loopback OAuth relay.

# Optional remote backend (defaults to local proxy when unset)
# YORK_IE_BACKEND_URL=http://127.0.0.1:3001
