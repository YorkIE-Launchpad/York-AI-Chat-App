# API Configuration 
# Required: Set your API authentication token 
# ANTHROPIC_AUTH_TOKEN=your_api_key_here 
 
# # Optional: Custom API endpoint 
# ANTHROPIC_BASE_URL=https://openrouter.ai/api 
 
# # Optional: Model selection 
# CLAUDE_MODEL=anthropic/claude-sonnet-4.5 
 
# Optional: Custom Claude Code CLI path 
# IMPORTANT: Use forward slashes (/) on Windows, not backslashes (\) 
# CLAUDE_CODE_PATH=C:/Users/yourname/AppData/Roaming/npm/node_modules/@anthropic-ai/claude-code/cli.js

# Hub / Cognito authentication (Launchpad-compatible)
# HUB_API_URL=https://api.uat-hub.yorkdevs.link
# VITE_HUB_API_URL=https://api.uat-hub.yorkdevs.link
# LAUNCHPAD_MCP_URL=https://launchpad.yorkdevs.link/mcp
# AWS_COGNITO_USER_POOL_ID=
# AWS_COGNITO_APP_CLIENT_ID=
# AUTH_ALLOWED_DOMAIN=@york.ie
# Hub must allow http://127.0.0.1:<port>/auth/callback for desktop OAuth.

#YORK_IE_BACKEND_URL=http://127.0.0.1:3001
# Local LLM proxy (backend/) — use the same Cognito pool/client IDs in backend/.env
# so proxy routes can verify JWTs. See backend/.env.example.
