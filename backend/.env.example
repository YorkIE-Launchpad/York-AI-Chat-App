PORT=3001

# Cloud provider API keys (only providers with keys appear in GET /models)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Cognito JWT verification (same pool/client as the Electron app)
# Required for /models and all provider proxy routes
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_APP_CLIENT_ID=
