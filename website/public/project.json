{
  "schemaVersion": "1.0",
  "name": "York IE VECOS",
  "organization": "York IE",
  "canonicalUrl": "https://york.ie/",
  "localizedUrls": {
    "en": "https://york.ie/"
  },
  "repository": "https://york.ie",
  "releases": "https://york.ie",
  "issues": "https://york.ie",
  "license": {
    "name": "MIT",
    "url": "https://opensource.org/licenses/MIT"
  },
  "version": "3.3.0",
  "lastReviewed": "2026-05-01",
  "description": "Open-source AI agent desktop app for Windows and macOS with one-click installation, sandbox isolation, multi-model support, built-in Skills, MCP integration, GUI automation, and remote control.",
  "applicationCategory": "DeveloperApplication",
  "platforms": ["Windows", "macOS"],
  "prebuiltInstallerTypes": {
    "Windows": ".exe",
    "macOS": ".dmg"
  },
  "sourceBuild": {
    "node": ">=22",
    "commands": ["npm install", "npm run rebuild", "npm run dev"]
  },
  "install": [
    {
      "platform": "macOS",
      "method": "Homebrew",
      "commands": ["brew tap YorkIE-Launchpad/tap", "brew install --cask --no-quarantine york-ie"]
    },
    {
      "platform": "Windows and macOS",
      "method": "GitHub Releases",
      "url": "https://york.ie"
    }
  ],
  "capabilities": [
    "Local AI agent desktop workspace",
    "Multi-model provider configuration",
    "Built-in Skills for PPTX, DOCX, XLSX, and PDF workflows",
    "Model Context Protocol tool integration",
    "GUI automation through computer use",
    "Remote control through Feishu (Lark) and Slack",
    "Workspace path restrictions",
    "VM sandbox isolation with WSL2 and Lima when available"
  ],
  "modelProviders": [
    {
      "name": "OpenRouter",
      "baseUrl": "https://openrouter.ai/api",
      "recommendedModels": ["claude-4-5-sonnet"]
    },
    {
      "name": "Anthropic",
      "baseUrl": "default",
      "recommendedModels": ["claude-4-5-sonnet"]
    },
    {
      "name": "Zhipu AI / GLM",
      "baseUrl": "https://open.bigmodel.cn/api/anthropic",
      "recommendedModels": ["glm-4.7", "glm-4.6"]
    },
    {
      "name": "MiniMax",
      "baseUrl": "https://api.minimaxi.com/anthropic",
      "recommendedModels": ["minimax-m2"]
    },
    {
      "name": "Kimi",
      "baseUrl": "https://api.kimi.com/coding/",
      "recommendedModels": ["kimi-k2"]
    }
  ],
  "securityAndPrivacy": {
    "localFirst": true,
    "workspaceBoundary": "File operations are restricted to the selected workspace folder.",
    "vmIsolation": ["WSL2 on Windows", "Lima on macOS"],
    "dataPolicy": "York IE VECOS runs locally; the external network path is the AI model API configured by the user. The project website states that York IE VECOS does not send data to York IE servers."
  },
  "machineReadableResources": {
    "llmsTxt": "https://york.ie/llms.txt",
    "llmsFullTxt": "https://york.ie/llms-full.txt",
    "projectJson": "https://york.ie/project.json",
    "sitemap": "https://york.ie/sitemap.xml",
    "robots": "https://york.ie/robots.txt"
  },
  "sourcePages": [
    "https://york.ie/blob/main/README.md",
    "https://york.ie/blob/main/CHANGELOG.md",
    "https://york.ie/blob/main/ROADMAP.md",
    "https://york.ie/blob/main/SECURITY.md",
    "https://york.ie/blob/main/CONTRIBUTING.md"
  ]
}
